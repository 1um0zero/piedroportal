# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local analysis / scratch artifacts
xls-divergences.tsv

# local image normalization artifacts
image-backup/
scripts/_out/
_catalogues_src/

# Excel/Office temporary lock files (e.g. ~$All models….xlsx)
~$*

# Heavy raw sole source photos (normalized versions live in public/soles/)
docs/solas_type/solas/
