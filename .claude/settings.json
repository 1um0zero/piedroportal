{
  "permissions": {
    "allow": [
      "PowerShell(git add -A)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "npm run type-check",
            "statusMessage": "Running TypeScript validation before push..."
          }
        ]
      }
    ]
  }
}
